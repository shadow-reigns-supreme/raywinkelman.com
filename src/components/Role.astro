---
import type { RoleVenture } from '../data/types';

interface Props {
  company: string;
  dates: string;
  title: string;
  location: string;
  description: string;
  ventures?: RoleVenture[];
}

const { company, dates, title, location, description, ventures } = Astro.props;
---

<article class="role">
  <div class="role-head">
    <h3 class="role-company">{company}</h3>
    <span class="role-dates">{dates}</span>
  </div>
  <p class="role-title">{title}<span class="role-location">{location}</span></p>
  <p class="role-desc">{description}</p>
  {ventures && ventures.length > 0 && (
    <div class="role-ventures">
      {ventures.map((v) => (
        <div class="role-venture">
          <img src={v.logo} alt={`${v.name} logo`} class="role-venture-logo" width="22" height="22" loading="lazy">
          <div>
            <a href={v.whitepaper} class="role-venture-name">{v.name}</a>
            <span class="role-venture-blurb">{v.blurb}</span>
          </div>
        </div>
      ))}
    </div>
  )}
</article>
