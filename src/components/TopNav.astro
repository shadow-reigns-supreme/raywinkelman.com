---
interface Props {
  currentPath: string;
  currentLang?: string;
}

const { currentPath, currentLang } = Astro.props;

const isProfile = currentPath === '/' || currentPath === '/es/' || currentPath === '/th/';
const isBlog = currentPath.startsWith('/blog');
---

<nav class="top-nav" aria-label="Site navigation">
  <a href="/" aria-current={isProfile ? 'page' : undefined}>Profile</a>
  <span class="nav-sep" aria-hidden="true">/</span>
  <a href="/blog/" aria-current={isBlog ? 'page' : undefined}>Blog</a>
  <span class="nav-sep" aria-hidden="true">/</span>
  <a class="nav-ext" href="https://shadowsoftware.com" target="_blank" rel="noopener">Shadow&nbsp;Software&nbsp;↗</a>

  {currentLang !== undefined && (
    <>
      <span class="nav-sep" aria-hidden="true">/</span>
      <div class="lang-drop" data-lang-drop>
        <button class="lang-drop-btn" type="button" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
          {currentLang === 'en' && <><span class="lang-flag" aria-hidden="true">🇺🇸</span> EN</>}
          {currentLang === 'es' && <><span class="lang-flag" aria-hidden="true">🇪🇸</span> ES</>}
          {currentLang === 'th' && <><span class="lang-flag" aria-hidden="true">🇹🇭</span> TH</>}
          <svg class="lang-chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="1,1 4,4 7,1"/>
          </svg>
        </button>
        <ul class="lang-drop-menu" role="listbox" aria-label="Select language">
          <li role="option" aria-selected={currentLang === 'en'}>
            <a href="/" hreflang="en"><span aria-hidden="true">🇺🇸</span> EN</a>
          </li>
          <li role="option" aria-selected={currentLang === 'es'}>
            <a href="/es/" hreflang="es"><span aria-hidden="true">🇪🇸</span> ES</a>
          </li>
          <li role="option" aria-selected={currentLang === 'th'}>
            <a href="/th/" hreflang="th"><span aria-hidden="true">🇹🇭</span> TH</a>
          </li>
        </ul>
      </div>
    </>
  )}
</nav>
