---
import Whitepaper from '../../layouts/Whitepaper.astro';

type Post = { title: string; description: string; href: string; date: string; category: string };

const PERMITTED_CATEGORIES = ['Tax', 'AEO', 'SEO', 'DabDash', 'Prepped', 'American Gun Trader', 'Guest Blog'];

let categories: string[] = [...PERMITTED_CATEGORIES];

try {
  const res = await fetch('https://n8n.americanguntrader.com/webhook/67a78c43-734d-407a-9bfe-da21cca71d34', {
    headers: { 'x-shadowmen': '508e7579-374c-47ec-9d6d-a024f9a65a89' },
  });
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data) && data.length > 0) categories = data;
  }
} catch (_) {}

const staticPosts: Post[] = [
  {
    title: 'Krabi Garuda Resort Review — Five Stars, No Reservations',
    description: 'An honest first-hand review of Krabi Garuda resort in Thailand — exceptional staff, seamless online booking, and a property that earns every star.',
    href: '/blog/krabi-vacation-review/',
    date: 'April 2026',
    category: 'Guest Blog',
  },
];

let dynamicPosts: Post[] = [];

try {
  const res = await fetch('https://n8n.americanguntrader.com/webhook/491d8b14-ea4f-48b1-bde4-d1136a023a41', {
    headers: { 'x-shadowmen': '508e7579-374c-47ec-9d6d-a024f9a65a89' },
  });
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data)) dynamicPosts = data;
  }
} catch (_) {}

const posts = [...staticPosts, ...dynamicPosts];
---

<Whitepaper
  title="Blog — Ray Winkelman"
  description="Tech entrepreneurship, AEO/SEO, offshore tax residencies, and travel — written by Ray Winkelman, founder of Shadow Software LLC."
  logo="/ray.png"
  platformName="Blog"
  platformUrl="https://raywinkelman.com/blog/"
  tagline="Tech entrepreneurship, AEO/SEO, offshore tax, and travel"
  path="/blog/"
>

<nav class="cat-nav" aria-label="Filter by category">
  <button class="cat-pill active" data-filter="All">All</button>
  {categories.map(cat => (
    <button class="cat-pill" data-filter={cat}>{cat}</button>
  ))}
</nav>

<h2>Posts</h2>

<ul class="blog-list">
  {posts.map((post) => (
    <li class="blog-item" data-category={post.category}>
      <div class="blog-item-meta">
        <span class="cat-badge">{post.category}</span>
        <span class="blog-meta">{post.date}</span>
      </div>
      <a href={post.href} class="blog-title">{post.title}</a>
      <p class="blog-desc">{post.description}</p>
    </li>
  ))}
</ul>

<p class="blog-empty" hidden>No posts in this category yet.</p>

</Whitepaper>

<style>
/* —— Hide "Visit Site" on blog index (links to itself) —— */
.wp-visit { display: none; }

/* —— Category nav —— */
.cat-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}

.cat-pill {
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.375rem 0.875rem;
  border: 1px solid var(--text-muted);
  border-radius: 2px;
  color: var(--text-muted);
  background: none;
  font-family: var(--font);
  cursor: pointer;
  line-height: 1;
  transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.cat-pill:hover {
  color: var(--accent);
  border-color: var(--accent);
}

.cat-pill.active {
  color: var(--bg);
  background: var(--text);
  border-color: var(--text);
}

/* —— Post list —— */
.blog-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.blog-item {
  padding: 1.375rem 0;
  border-bottom: 1px solid var(--rule);
}

.blog-item:first-child {
  padding-top: 0;
}

.blog-item-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.375rem;
}

.cat-badge {
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  padding: 0.125rem 0.5rem;
  border-radius: 2px;
  white-space: nowrap;
}

.blog-meta {
  font-size: 0.6875rem;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.blog-title {
  font-size: 0.9375rem;
  font-weight: 600;
  display: block;
  margin-bottom: 0.375rem;
  color: var(--text);
  transition: color 0.15s ease;
}

.blog-title:hover {
  color: var(--accent);
  text-decoration: none;
}

.blog-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.6;
}

.blog-empty {
  color: var(--text-muted);
  font-size: 0.875rem;
}
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
  const items = document.querySelectorAll<HTMLLIElement>('.blog-item');
  const empty = document.querySelector<HTMLParagraphElement>('.blog-empty');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter!;

      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');

      let visible = 0;
      items.forEach(item => {
        const show = filter === 'All' || item.dataset.category === filter;
        item.hidden = !show;
        if (show) visible++;
      });

      if (empty) empty.hidden = visible > 0;
    });
  });
</script>
