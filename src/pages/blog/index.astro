---
import Whitepaper from '../../layouts/Whitepaper.astro';

export const prerender = true;

interface Post { title: string; description: string; href: string; date: string; category: string }
interface RawPost { title: string; excerpt: string; slug: string; published_at: string; category: string }

const modules = import.meta.glob('../../content/posts/*.json', { eager: true }) as Record<string, RawPost>;

const posts: Post[] = Object.values(modules)
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .map((p) => ({
    title: p.title,
    description: p.excerpt,
    href: `/blog/${p.slug}/`,
    date: new Date(p.published_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),
    category: p.category,
  }));

const PERMITTED_CATEGORIES = ['Software Development', 'AEO', 'SEO', 'Cold Email', 'Cybersecurity', 'Guest Blog'];
const presentCategories = new Set(posts.map((p) => p.category));
const categories = PERMITTED_CATEGORIES.filter((c) => presentCategories.has(c));
---

<Whitepaper
  title="Blog — Ray Winkelman"
  description="Software engineering, SEO/AEO, and outbound systems — written by Ray Winkelman, founder of Shadow Software LLC."
  logo="/big-shadow.png"
  platformName="Blog"
  platformUrl="https://raywinkelman.com/blog/"
  tagline="Software engineering, SEO/AEO, and outbound systems"
  path="/blog/"
  showVisitLink={false}
  isIndex={true}
>

<nav class="cat-nav" aria-label="Filter by category">
  <button class="cat-pill active" data-filter="All" aria-pressed="true">All</button>
  {categories.map(cat => (
    <button class="cat-pill" data-filter={cat} aria-pressed="false">{cat}</button>
  ))}
</nav>

<h2>Posts</h2>

<ul class="blog-list">
  {posts.map((post) => (
    <li class="blog-item" data-category={post.category}>
      <div class="blog-item-meta">
        <span class="cat-badge">{post.category}</span>
        <span class="blog-meta">{post.date}</span>
      </div>
      <a href={post.href} class="blog-title">{post.title}</a>
      <p class="blog-desc">{post.description}</p>
    </li>
  ))}
</ul>

<p class="blog-empty" hidden>No posts in this category yet.</p>

</Whitepaper>

<style>
/* —— Category nav —— */
.cat-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}

.cat-pill {
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.5rem 0.875rem;
  border: 1px solid var(--text-muted);
  border-radius: 2px;
  color: var(--text-muted);
  background: none;
  font-family: var(--font);
  cursor: pointer;
  line-height: 1;
  min-height: 32px;
  transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.cat-pill:hover {
  color: var(--accent);
  border-color: var(--accent);
}

.cat-pill.active {
  color: var(--bg);
  background: var(--text);
  border-color: var(--text);
}

/* —— Post list —— */
.blog-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.blog-item {
  padding: 1.375rem 0;
  border-bottom: 1px solid var(--rule);
}

.blog-item:first-child {
  padding-top: 0;
}

.blog-item-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.375rem;
}

.cat-badge {
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  padding: 0.125rem 0.5rem;
  border-radius: 2px;
  white-space: nowrap;
}

.blog-meta {
  font-size: 0.6875rem;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.blog-title {
  font-size: 0.9375rem;
  font-weight: 600;
  display: block;
  margin-bottom: 0.375rem;
  color: var(--text);
  transition: color 0.15s ease;
}

.blog-title:hover {
  color: var(--accent);
  text-decoration: none;
}

.blog-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.6;
}

.blog-empty {
  color: var(--text-muted);
  font-size: 0.875rem;
}
</style>

<script>
  function initBlogFilter() {
    const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
    const items = document.querySelectorAll<HTMLLIElement>('.blog-item');
    const empty = document.querySelector<HTMLParagraphElement>('.blog-empty');
    if (!pills.length) return;

    function applyFilter(filter: string) {
      for (const p of pills) { p.classList.remove('active'); p.setAttribute('aria-pressed', 'false'); }
      const activePill = [...pills].find(p => p.dataset.filter === filter);
      if (activePill) { activePill.classList.add('active'); activePill.setAttribute('aria-pressed', 'true'); }

      let visible = 0;
      for (const item of items) {
        const cat = item.dataset.category?.toLowerCase();
        const show = filter === 'All'
          ? cat !== 'guest blog'
          : cat === filter.toLowerCase();
        item.hidden = !show;
        if (show) visible++;
      }
      if (empty) empty.hidden = visible > 0;
    }

    applyFilter('All');

    for (const pill of pills) {
      pill.addEventListener('click', () => applyFilter(pill.dataset.filter ?? 'All'));
    }
  }

  document.addEventListener('astro:page-load', initBlogFilter);
</script>
