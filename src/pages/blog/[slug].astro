---
import Whitepaper from '../../layouts/Whitepaper.astro';

export const prerender = true;

interface Post {
  title: string;
  excerpt: string;
  html: string;
  category: string;
  keyword: string;
  lang: string;
  slug: string;
  published_at: string;
  image_url?: string;
}

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/posts/*.json', { eager: true }) as Record<string, Post>;
  return Object.values(modules).map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const date = new Date(post.published_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

type PromoVariant = 'seo' | 'software' | 'outbound' | 'brand';
const VARIANT_BY_CATEGORY: Record<string, PromoVariant> = {
  'AEO': 'seo',
  'SEO': 'seo',
  'Cold Email': 'outbound',
  'Software Development': 'software',
  'Cybersecurity': 'software',
};
// Everything else (Guest Blog: venture promos, SaaS guest placements) gets the brand pitch
const promoVariant: PromoVariant = VARIANT_BY_CATEGORY[post.category] ?? 'brand';
---

<Whitepaper
  title={`${post.title} — Ray Winkelman`}
  description={post.excerpt}
  lang={post.lang ?? 'en'}
  logo="/big-shadow.png"
  platformName={post.title}
  platformUrl="https://raywinkelman.com/blog/"
  tagline={`${post.category} · ${date}`}
  path={`/blog/${post.slug}/`}
  datePublished={post.published_at}
  showVisitLink={false}
  featuredImage={`/blog-img/${post.slug}.avif`}
  promoVariant={promoVariant}
>

<Fragment set:html={post.html} />

</Whitepaper>
