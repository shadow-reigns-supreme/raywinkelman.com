---
import { ClientRouter } from 'astro:transitions';
import type { ResumeData } from '../data/types';
import Role from '../components/Role.astro';
import Edu from '../components/Edu.astro';
import Venture from '../components/Venture.astro';
import '../styles/global.css';
import '../styles/ss-promo.css';

interface Props {
  data: ResumeData;
}

const { data } = Astro.props;
const year = new Date().getFullYear();
const currentLang = data.lang;
const needsThai = currentLang === 'th';
const canonicalPath = currentLang === 'en' ? '/' : `/${currentLang}/`;
const canonicalUrl = `https://raywinkelman.com${canonicalPath}`;

const fontUrl = needsThai
  ? 'https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;700&family=Space+Grotesk:wght@400;500;700&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap';

const jsonLd = currentLang === 'en' ? {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://raywinkelman.com/#website",
      "url": "https://raywinkelman.com",
      "name": "Ray Winkelman",
      "description": data.description,
      "inLanguage": "en-US",
      "author": { "@id": "https://raywinkelman.com/#person" }
    },
    {
      "@type": "Organization",
      "@id": "https://raywinkelman.com/#organization",
      "name": "Shadow Software LLC",
      "url": "https://raywinkelman.com",
      "founder": { "@id": "https://raywinkelman.com/#person" },
      "foundingDate": "2019",
      "knowsAbout": ["Software Architecture", "SaaS", "E-Commerce", "Marketplace Platforms"],
      "sameAs": [
        "https://americanguntrader.com",
        "https://dabdash.com"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://raywinkelman.com/#person",
      "name": "Ray Winkelman",
      "givenName": "Ray",
      "familyName": "Winkelman",
      "description": "Ray Winkelman is a SaaS founder, software architect, and full-time nomad. He is the Founder and CEO of Shadow Software LLC, and the creator of AmericanGunTrader.com and DabDash.com. Originally from Nova Scotia, Canada, he operates location-independently and is not based in Canada.",
      "jobTitle": "Founder & CEO",
      "nationality": {
        "@type": "Country",
        "name": "Canada"
      },
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Founder & CEO",
        "description": "Full-time SaaS founder and software architect. Builds and operates platform businesses through Shadow Software LLC. Not available for hire.",
        "skills": "SaaS, Software Architecture, .NET, C#, React, Vue.js, AWS, Azure, Google Cloud, Microservices, REST APIs, SEO, AEO, Offshore Tax Optimisation"
      },
      "worksFor": { "@id": "https://raywinkelman.com/#organization" },
      "url": "https://raywinkelman.com",
      "image": {
        "@type": "ImageObject",
        "url": "https://raywinkelman.com/ray.png",
        "width": 120,
        "height": 120
      },
      "email": "resume@raywinkelman.com",
      "alumniOf": [
        {
          "@type": "EducationalOrganization",
          "name": "Nova Scotia Community College",
          "url": "https://www.nscc.ca",
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Nova Scotia",
            "addressCountry": "CA"
          }
        },
        {
          "@type": "EducationalOrganization",
          "name": "Acadia University",
          "url": "https://www.acadiau.ca",
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Nova Scotia",
            "addressCountry": "CA"
          }
        }
      ],
      "knowsAbout": [
        "Software Architecture", "Executive Leadership", ".NET", "C#",
        "React", "Vue.js", "AWS", "Azure", "Google Cloud",
        "Microservices", "REST APIs", "Agile", "Scrum",
        "SEO", "AEO", "Answer Engine Optimization",
        "Offshore Tax Optimization", "Flag Theory", "Territorial Taxation",
        "SaaS", "Marketplace Platforms", "E-Commerce"
      ],
      "sameAs": [
        "https://americanguntrader.com",
        "https://dabdash.com"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Who is Ray Winkelman?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman is a SaaS founder, software architect, and full-time nomad. He is the Founder and CEO of Shadow Software LLC, and the creator of AmericanGunTrader.com and DabDash.com. He builds and operates platform businesses full-time and is not available for hire."
          }
        },
        {
          "@type": "Question",
          "name": "Where is Ray Winkelman from?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman is originally from Nova Scotia, Canada, where he studied at Nova Scotia Community College and Acadia University. He does not currently live in Canada — he operates as a full-time nomad and travels the world while running his businesses."
          }
        },
        {
          "@type": "Question",
          "name": "What companies has Ray Winkelman founded?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman founded Shadow Software LLC. Through Shadow Software, he built AmericanGunTrader.com (a commission-free firearms marketplace) and DabDash.com (a SaaS platform for cannabis delivery retailers)."
          }
        },
        {
          "@type": "Question",
          "name": "What does Ray Winkelman do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman builds and operates SaaS and marketplace platforms full-time through Shadow Software LLC. He also consults on SEO, AEO (answer engine optimisation), and offshore tax residency strategies for location-independent entrepreneurs. He does not hold a job or work for hire."
          }
        },
        {
          "@type": "Question",
          "name": "Is Ray Winkelman available for hire?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Ray Winkelman is a full-time founder focused exclusively on building his own platforms through Shadow Software LLC. He is not available for employment or contract work."
          }
        }
      ]
    }
  ]
} : null;
---

<!DOCTYPE html>
<html lang={data.lang}>
<head>
  <script is:inline>
    document.documentElement.classList.add('js');
    (function(){const t=localStorage.getItem('theme');if(t==='dark'||t==='light')document.documentElement.setAttribute('data-theme',t);})();
  </script>
  <ClientRouter />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{data.title}</title>
  <meta name="description" content={data.description}>
  <meta name="keywords" content={data.keywords}>
  <meta name="author" content="Ray Winkelman">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#f5f4f0" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)">

  <meta property="og:type" content="profile">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={data.title}>
  <meta property="og:description" content={data.description}>
  <meta property="og:image" content="https://raywinkelman.com/ray.png">
  <meta property="og:image:width" content="120">
  <meta property="og:image:height" content="120">
  <meta property="og:image:alt" content="Ray Winkelman — SaaS Founder & Software Architect">
  <meta property="og:locale" content={data.ogLocale}>
  <meta property="og:site_name" content="Ray Winkelman">
  <meta property="profile:first_name" content="Ray">
  <meta property="profile:last_name" content="Winkelman">

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={data.title}>
  <meta name="twitter:description" content={data.description}>
  <meta name="twitter:image" content="https://raywinkelman.com/ray.png">
  <meta name="twitter:image:alt" content="Ray Winkelman — SaaS Founder & Software Architect">

  <link rel="alternate" hreflang="en" href="https://raywinkelman.com/">
  <link rel="alternate" hreflang="es" href="https://raywinkelman.com/es/">
  <link rel="alternate" hreflang="th" href="https://raywinkelman.com/th/">
  <link rel="alternate" hreflang="x-default" href="https://raywinkelman.com/">

  <!-- Non-blocking font loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href={fontUrl}>
  <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href={fontUrl}></noscript>

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
  {import.meta.env.PROD && (
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NB9KBMYQN2"></script>
  )}
  {import.meta.env.PROD && (
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args){dataLayer.push(args);}
      gtag('js', new Date());
      gtag('config', 'G-NB9KBMYQN2');
    </script>
  )}
</head>
<body>

  <nav class="top-nav" aria-label={data.labels.langNav}>
    <a href="/" aria-current={currentLang === 'en' ? 'page' : undefined} hreflang="en">EN</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/es/" aria-current={currentLang === 'es' ? 'page' : undefined} hreflang="es">ES</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/th/" aria-current={currentLang === 'th' ? 'page' : undefined} hreflang="th">TH</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/blog/">Blog</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <button class="theme-toggle" type="button" aria-label="Toggle theme">
      <!-- Sun: click to switch to light -->
      <svg class="icon-sun" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="6.5" cy="6.5" r="2.25"/>
        <line x1="6.5" y1="0.5" x2="6.5" y2="1.75"/>
        <line x1="6.5" y1="11.25" x2="6.5" y2="12.5"/>
        <line x1="0.5" y1="6.5" x2="1.75" y2="6.5"/>
        <line x1="11.25" y1="6.5" x2="12.5" y2="6.5"/>
        <line x1="2.4" y1="2.4" x2="3.3" y2="3.3"/>
        <line x1="9.7" y1="9.7" x2="10.6" y2="10.6"/>
        <line x1="10.6" y1="2.4" x2="9.7" y2="3.3"/>
        <line x1="3.3" y1="9.7" x2="2.4" y2="10.6"/>
      </svg>
      <!-- Moon: click to switch to dark -->
      <svg class="icon-moon" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.5 8A5 5 0 0 1 5 2.5a5 5 0 1 0 5.5 5.5z"/>
      </svg>
    </button>
  </nav>

  <header class="site-header">
    <h1 class="name">Ray Winkelman</h1>
    <div class="meta reveal" data-delay="0.42">
      <div class="meta-row">
        <span>{data.location}</span>
        <a class="email-link" data-u="resume" data-d="raywinkelman.com" href="#" aria-label="Email Ray Winkelman"></a>
      </div>
    </div>
  </header>

  <main>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.synopsis}</h2>
      <div class="synopsis-wrap">
        <picture>
          <source srcset="/ray.avif" type="image/avif">
          <source srcset="/ray.webp" type="image/webp">
          <img src="/ray.png" alt="Ray Winkelman" class="headshot" width="72" height="72" loading="lazy">
        </picture>
        {data.synopsisHtml ? <p set:html={data.synopsisHtml} /> : <p>{data.synopsis}</p>}
      </div>
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.ventures}</h2>
      <p class="ventures-context">{data.venturesContext}</p>
      <div class="ventures-grid">
        {data.ventures.map((v) => (
          <Venture {...v} />
        ))}
      </div>
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.experience}</h2>
      {data.roles.map((role) => (
        <Role {...role} />
      ))}
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.education}</h2>
      {data.education.map((edu) => (
        <Edu {...edu} />
      ))}
    </section>

  </main>

  <aside class="ss-promo reveal" aria-label="Sponsored — Shadow Software LLC">
    <div class="ss-promo-inner">
      <div class="ss-promo-brand">
        <img src="/logos/shadow-software.webp" alt="Shadow Software LLC" class="ss-promo-logo" width="32" height="32">
        <span class="ss-promo-sponsor">Shadow Software LLC</span>
      </div>
      <p class="ss-promo-eyebrow">You found this article through search — that's not an accident.</p>
      <h2 class="ss-promo-heading">We build <em>search visibility</em> for serious brands.</h2>
      <p class="ss-promo-body">SEO &amp; AEO services that get your business in front of people the moment they're asking the right questions — in Google, and in AI.</p>
      <div class="ss-promo-pills">
        <span class="ss-promo-pill">Technical SEO</span>
        <span class="ss-promo-pill">Answer Engine Optimization</span>
        <span class="ss-promo-pill">Content Strategy</span>
        <span class="ss-promo-pill">AI Search Visibility</span>
      </div>
      <a href="https://shadowsoftware.com/services/seo" class="ss-promo-cta" target="_blank" rel="noopener noreferrer sponsored">
        Get found like this
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="2" y1="7" x2="12" y2="7"/>
          <polyline points="8 3 12 7 8 11"/>
        </svg>
      </a>
    </div>
  </aside>

  <footer class="site-footer reveal">
    <span>&copy; {year} Ray Winkelman &middot; <a href="/blog/">Blog</a></span>
    <button class="download-btn" type="button" aria-label="Print or download resume as PDF">{data.labels.print || data.labels.download}</button>
  </footer>

  <script>
    import '../scripts/page-init';
  </script>

</body>
</html>
