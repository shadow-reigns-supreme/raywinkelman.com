---
import { ClientRouter } from 'astro:transitions';
import type { ResumeData } from '../data/types';
import Role from '../components/Role.astro';
import Edu from '../components/Edu.astro';
import Venture from '../components/Venture.astro';
import Funnel from '../components/Funnel.astro';
import TopNav from '../components/TopNav.astro';
import { fillYears } from '../data/career';
import '../styles/global.css';

interface Props {
  data: ResumeData;
}

const { data } = Astro.props;
const year = new Date().getFullYear();

// Substitute the {years} token (engineering tenure) so the figure stays
// correct over time without hand edits. See src/data/career.ts.
const heroProof = data.hero.proof.map((item) => fillYears(item));
const synopsisHtml = data.synopsisHtml ? fillYears(data.synopsisHtml) : undefined;
const synopsisText = fillYears(data.synopsis);
const currentLang = data.lang;
const needsThai = currentLang === 'th';
const canonicalPath = currentLang === 'en' ? '/' : `/${currentLang}/`;
const canonicalUrl = `https://raywinkelman.com${canonicalPath}`;

const fontUrl = needsThai
  ? 'https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700;800&family=DM+Sans:wght@400;500;600;700&family=Noto+Sans+Thai:wght@400;500;700&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap';

const jsonLd = currentLang === 'en' ? {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://raywinkelman.com/#website",
      "url": "https://raywinkelman.com",
      "name": "Ray Winkelman",
      "description": data.description,
      "inLanguage": "en-US",
      "author": { "@id": "https://raywinkelman.com/#person" }
    },
    {
      "@type": "Organization",
      "@id": "https://raywinkelman.com/#organization",
      "name": "Shadow Software LLC",
      "url": "https://shadowsoftware.com",
      "founder": { "@id": "https://raywinkelman.com/#person" },
      "foundingDate": "2019",
      "knowsAbout": ["Software Architecture", "SaaS", "E-Commerce", "Marketplace Platforms"],
      "sameAs": [
        "https://americanguntrader.com",
        "https://dabdash.com"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://raywinkelman.com/#person",
      "name": "Ray Winkelman",
      "givenName": "Ray",
      "familyName": "Winkelman",
      "description": "Ray Winkelman is a SaaS founder, software architect, and full-time nomad. He is the Founder and CEO of Shadow Software LLC, and the creator of AmericanGunTrader.com and DabDash.com. Originally from Nova Scotia, Canada, he operates location-independently and is not based in Canada.",
      "jobTitle": "Founder & CEO",
      "nationality": {
        "@type": "Country",
        "name": "Canada"
      },
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Founder & CEO",
        "description": "Full-time SaaS founder and software architect. Builds and operates platform businesses through Shadow Software LLC. Not available for hire.",
        "skills": "SaaS, Software Architecture, .NET, C#, React, Vue.js, AWS, Azure, Google Cloud, Microservices, REST APIs, SEO, AEO, Offshore Tax Optimisation"
      },
      "worksFor": { "@id": "https://raywinkelman.com/#organization" },
      "url": "https://raywinkelman.com",
      "image": {
        "@type": "ImageObject",
        "url": "https://raywinkelman.com/big-shadow.png",
        "width": 512,
        "height": 512
      },
      "alumniOf": [
        {
          "@type": "EducationalOrganization",
          "name": "Nova Scotia Community College",
          "url": "https://www.nscc.ca",
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Nova Scotia",
            "addressCountry": "CA"
          }
        },
        {
          "@type": "EducationalOrganization",
          "name": "Acadia University",
          "url": "https://www.acadiau.ca",
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Nova Scotia",
            "addressCountry": "CA"
          }
        }
      ],
      "knowsAbout": [
        "Software Architecture", "Executive Leadership", ".NET", "C#",
        "React", "Vue.js", "AWS", "Azure", "Google Cloud",
        "Microservices", "REST APIs", "Agile", "Scrum",
        "SEO", "AEO", "Answer Engine Optimization",
        "Offshore Tax Optimization", "Flag Theory", "Territorial Taxation",
        "SaaS", "Marketplace Platforms", "E-Commerce"
      ],
      "sameAs": [
        "https://americanguntrader.com",
        "https://dabdash.com"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Who is Ray Winkelman?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman is a SaaS founder, software architect, and full-time nomad. He is the Founder and CEO of Shadow Software LLC, and the creator of AmericanGunTrader.com and DabDash.com. He builds and operates platform businesses full-time and is not available for hire."
          }
        },
        {
          "@type": "Question",
          "name": "Where is Ray Winkelman from?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman is originally from Nova Scotia, Canada, where he studied at Nova Scotia Community College and Acadia University. He does not currently live in Canada — he operates as a full-time nomad and travels the world while running his businesses."
          }
        },
        {
          "@type": "Question",
          "name": "What companies has Ray Winkelman founded?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman founded Shadow Software LLC. Through Shadow Software, he built AmericanGunTrader.com (a commission-free firearms marketplace) and DabDash.com (a SaaS platform for cannabis delivery retailers)."
          }
        },
        {
          "@type": "Question",
          "name": "What does Ray Winkelman do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ray Winkelman builds and operates SaaS and marketplace platforms full-time through Shadow Software LLC. Through Shadow Software, his team takes on client engagements in software development, SEO and AEO (answer engine optimisation), and cold email outbound systems. He does not hold a job or work for hire."
          }
        },
        {
          "@type": "Question",
          "name": "Is Ray Winkelman available for hire?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Ray Winkelman is a full-time founder focused exclusively on building his own platforms through Shadow Software LLC. He is not available for employment or contract work."
          }
        }
      ]
    }
  ]
} : null;
---

<!DOCTYPE html>
<html lang={data.lang}>
<head>
  <script is:inline>
    document.documentElement.classList.add('js');
  </script>
  <ClientRouter />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{data.title}</title>
  <meta name="description" content={data.description}>
  <meta name="keywords" content={data.keywords}>
  <meta name="author" content="Ray Winkelman">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="color-scheme" content="dark">
  <meta name="theme-color" content="#060606">

  <meta property="og:type" content="profile">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={data.title}>
  <meta property="og:description" content={data.description}>
  <meta property="og:image" content="https://raywinkelman.com/big-shadow.png">
  <meta property="og:image:width" content="512">
  <meta property="og:image:height" content="512">
  <meta property="og:image:alt" content="Big Shadow — avatar of Ray Winkelman, founder of Shadow Software LLC">
  <meta property="og:locale" content={data.ogLocale}>
  <meta property="og:site_name" content="Ray Winkelman">
  <meta property="profile:first_name" content="Ray">
  <meta property="profile:last_name" content="Winkelman">

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={data.title}>
  <meta name="twitter:description" content={data.description}>
  <meta name="twitter:image" content="https://raywinkelman.com/big-shadow.png">
  <meta name="twitter:image:alt" content="Big Shadow — avatar of Ray Winkelman, founder of Shadow Software LLC">

  <link rel="alternate" hreflang="en" href="https://raywinkelman.com/">
  <link rel="alternate" hreflang="es" href="https://raywinkelman.com/es/">
  <link rel="alternate" hreflang="th" href="https://raywinkelman.com/th/">
  <link rel="alternate" hreflang="x-default" href="https://raywinkelman.com/">

  <!-- Non-blocking font loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href={fontUrl}>
  <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href={fontUrl}></noscript>

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
  {import.meta.env.PROD && (
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NB9KBMYQN2"></script>
  )}
  {import.meta.env.PROD && (
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args){dataLayer.push(args);}
      gtag('js', new Date());
      gtag('config', 'G-NB9KBMYQN2');
    </script>
  )}
</head>
<body>

  <div id="nav-progress" aria-hidden="true"></div>
  <TopNav currentPath={canonicalPath} currentLang={currentLang} />

  <header class="site-header">
    <p class="kicker">{data.hero.kicker}</p>
    <h1 class="name">Ray Winkelman</h1>
    <p class="position-line reveal" set:html={data.hero.positionHtml} />
    <div class="proof-strip reveal" data-delay="0.1">
      {heroProof.map((item) => (
        <span set:html={item} />
      ))}
    </div>
    <div class="hero-cta reveal" data-delay="0.2">
      <a class="btn btn--primary" href="https://shadowsoftware.com/contact" rel="noopener">
        {data.hero.ctaPrimary}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="2" y1="7" x2="12" y2="7"/>
          <polyline points="8 3 12 7 8 11"/>
        </svg>
      </a>
      <a class="btn btn--ghost" href="/blog/">{data.hero.ctaSecondary}</a>
    </div>
  </header>

  <main>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.synopsis}</h2>
      <div class="synopsis-wrap">
        <picture>
          <source srcset="/big-shadow.avif" type="image/avif">
          <source srcset="/big-shadow.webp" type="image/webp">
          <img src="/big-shadow.webp" alt="Big Shadow — cartoon avatar of Ray Winkelman" class="headshot" width="84" height="84" loading="lazy">
        </picture>
        {synopsisHtml ? <p set:html={synopsisHtml} /> : <p>{synopsisText}</p>}
      </div>
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.ventures}</h2>
      <p class="ventures-context">{data.venturesContext}</p>
      <div class="ventures-grid">
        {data.ventures.map((v) => (
          <Venture {...v} />
        ))}
      </div>
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.experience}</h2>
      {data.roles.map((role) => (
        <Role {...role} />
      ))}
    </section>

    <section class="section reveal">
      <h2 class="section-label">{data.labels.education}</h2>
      {data.education.map((edu) => (
        <Edu {...edu} />
      ))}
    </section>

  </main>

  <Funnel funnel={data.funnel} />

  <footer class="site-footer reveal">
    <span>&copy; {year} Ray Winkelman &middot; <a href="/blog/">Blog</a></span>
    <button class="download-btn" type="button" aria-label="Print or download resume as PDF">{data.labels.print || data.labels.download}</button>
  </footer>

  <script>
    import '../scripts/page-init';
  </script>

</body>
</html>
