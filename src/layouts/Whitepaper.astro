---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/whitepaper.css';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  lang?: string;
  logo: string;
  platformName: string;
  platformUrl: string;
  tagline: string;
  path: string;
  datePublished?: string;
  dateModified?: string;
  showVisitLink?: boolean;
  faqItems?: FaqItem[];
}

const { title, description, lang = 'en', logo, platformName, platformUrl, tagline, path, datePublished, dateModified, showVisitLink = true, faqItems } = Astro.props;
const year = new Date().getFullYear();
const canonicalUrl = `https://raywinkelman.com${path}`;
const fontUrl = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap';

// Always derive AVIF and WebP paths — all assets have been converted
const logoAvif = logo.replace(/\.[^.]+$/, '.avif');
const logoWebp = logo.replace(/\.[^.]+$/, '.webp');

const resolvedDateModified = dateModified ?? datePublished;

const jsonLdGraph: object[] = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ray Winkelman", "item": "https://raywinkelman.com/" },
      { "@type": "ListItem", "position": 2, "name": platformName, "item": canonicalUrl }
    ]
  },
  {
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "url": canonicalUrl,
    ...(datePublished ? { "datePublished": datePublished, "dateModified": resolvedDateModified } : {}),
    "author": {
      "@type": "Person",
      "@id": "https://raywinkelman.com/#person",
      "name": "Ray Winkelman",
      "url": "https://raywinkelman.com"
    },
    "publisher": {
      "@type": "Organization",
      "@id": "https://raywinkelman.com/#organization",
      "name": "Shadow Software LLC",
      "url": "https://raywinkelman.com"
    },
    "image": `https://raywinkelman.com${logo}`,
    "mainEntityOfPage": canonicalUrl
  }
];

if (faqItems && faqItems.length > 0) {
  jsonLdGraph.push({
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": jsonLdGraph };
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <script is:inline>document.documentElement.classList.add('js')</script>
  <ClientRouter />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Ray Winkelman">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="theme-color" content="#f5f4f0" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)">

  <meta property="og:type" content="article">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`https://raywinkelman.com${logo}`}>
  <meta property="og:image:width" content="64">
  <meta property="og:image:height" content="64">
  <meta property="og:site_name" content="Ray Winkelman">

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`https://raywinkelman.com${logo}`}>

  <link rel="alternate" hreflang="en" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>

  <!-- Preload LCP logo asset (AVIF) -->
  <link rel="preload" as="image" href={logoAvif} type="image/avif" fetchpriority="high">

  <!-- Non-blocking font loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href={fontUrl}>
  <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href={fontUrl}></noscript>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <nav class="top-nav" aria-label="Site navigation">
    <a href="/">Resume</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/americanguntrader/" aria-current={path === '/americanguntrader/' ? 'page' : undefined}>AGT</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/dabdash/" aria-current={path === '/dabdash/' ? 'page' : undefined}>DabDash</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/orderprepped/" aria-current={path === '/orderprepped/' ? 'page' : undefined}>Prepped</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/blog/" aria-current={path.startsWith('/blog') ? 'page' : undefined}>Blog</a>
  </nav>

  <header class="wp-header reveal">
    <div class="wp-brand">
      <picture>
        <source srcset={logoAvif} type="image/avif">
        <source srcset={logoWebp} type="image/webp">
        <img src={logo} alt={`${platformName} logo`} class="wp-logo" width="48" height="48" fetchpriority="high">
      </picture>
      <div>
        <h1 class="wp-title">{platformName}</h1>
        <p class="wp-tagline">{tagline}</p>
      </div>
    </div>
    {showVisitLink && <a href={platformUrl} class="wp-visit" rel="noopener noreferrer" target="_blank">Visit site</a>}
  </header>

  <main class="wp-body">
    <slot />
    {faqItems && faqItems.length > 0 && (
      <section class="wp-faq">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="wp-faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </section>
    )}
  </main>

  <footer class="site-footer reveal">
    <span>&copy; {year} Ray Winkelman &middot; Shadow Software LLC</span>
    <a href="/">Back to resume</a>
  </footer>

  <script>
    // —— Outbound UTM ——
    for (const a of document.querySelectorAll('a[href]')) {
  const href = a.getAttribute('href');
  if (!href || !href.startsWith('http') || href.includes('raywinkelman.com')) continue;
  try {
    const u = new URL(href);
    if (!u.searchParams.has('utm_source')) {
      u.searchParams.set('utm_source', 'raywinkelman.com');
      a.setAttribute('href', u.toString());
    }
  } catch {}
}

    // —— Scroll reveal (header + footer) ——
    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }
      }, { rootMargin: '0px 0px -30px 0px', threshold: 0.05 });
      for (const [i, el] of reveals.entries()) {
    el.style.setProperty('--reveal-delay', `${i * 0.07}s`);
    io.observe(el);
  }
    } else {
      for (const el of reveals) el.classList.add('visible');
    }

    // —— wp-body child reveals ——
    const wpBody = document.querySelector('.wp-body');
    if (wpBody && 'IntersectionObserver' in window) {
      const children = Array.from(wpBody.children);
      const wpIo = new IntersectionObserver((entries) => {
        for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('visible'); wpIo.unobserve(e.target); }
    }
      }, { rootMargin: '0px 0px -20px 0px', threshold: 0.05 });
      for (const [i, el] of children.entries()) {
    el.style.setProperty('--wp-i', String(i));
    wpIo.observe(el);
  }
    }

    // —— Nav backdrop on scroll ——
    if (!window.__navScrollBound) {
      window.__navScrollBound = true;
      window.addEventListener('scroll', () => {
        const n = document.querySelector('.top-nav');
        if (n) n.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });
    }
  </script>

</body>
</html>
