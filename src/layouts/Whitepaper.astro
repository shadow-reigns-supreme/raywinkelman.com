---
import { ClientRouter } from 'astro:transitions';
import ShadowSoftwarePromo from '../components/ShadowSoftwarePromo.astro';
import TopNav from '../components/TopNav.astro';
import '../styles/global.css';
import '../styles/whitepaper.css';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  lang?: string;
  logo: string;
  platformName: string;
  platformUrl: string;
  tagline: string;
  path: string;
  datePublished?: string;
  dateModified?: string;
  showVisitLink?: boolean;
  faqItems?: FaqItem[];
  featuredImage?: string;
  promoVariant?: 'seo' | 'software' | 'outbound' | 'brand';
  isIndex?: boolean;
}

const { title, description, lang = 'en', logo, platformName, platformUrl, tagline, path, datePublished, dateModified, showVisitLink = true, faqItems, featuredImage, promoVariant = 'seo', isIndex = false } = Astro.props;
const year = new Date().getFullYear();
const canonicalUrl = `https://raywinkelman.com${path}`;
const fontUrl = 'https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap';

// Always derive AVIF and WebP paths — all assets have been converted
const logoAvif = logo.replace(/\.[^.]+$/, '.avif');
const logoWebp = logo.replace(/\.[^.]+$/, '.webp');

// Featured image paths (AVIF primary, WebP fallback)
const featuredImageAvif = featuredImage ? featuredImage.replace(/\.[^.]+$/, '.avif') : null;
const featuredImageWebp = featuredImage ? featuredImage.replace(/\.[^.]+$/, '.webp') : null;

// LCP asset to preload — featured image takes priority over logo
const lcpPreload = featuredImageAvif ?? logoAvif;
const lcpPreloadType = 'image/avif';

// OG/Twitter image — featured image (1200×630) or logo fallback.
// Use WebP variant for social sharing — AVIF is not supported by Facebook/LinkedIn/Twitter scrapers.
const ogImage = featuredImage ? `https://raywinkelman.com${featuredImageWebp}` : `https://raywinkelman.com${logo}`;
const ogImageWidth = featuredImage ? '1200' : '512';
const ogImageHeight = featuredImage ? '630' : '512';

const resolvedDateModified = dateModified ?? datePublished;

const blogPostingImage = featuredImage
  ? {
      "@type": "ImageObject",
      "url": `https://raywinkelman.com${featuredImageAvif}`,
      "width": 1200,
      "height": 630
    }
  : `https://raywinkelman.com${logo}`;

const jsonLdGraph: object[] = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ray Winkelman", "item": "https://raywinkelman.com/" },
      { "@type": "ListItem", "position": 2, "name": platformName, "item": canonicalUrl }
    ]
  },
];

// Only emit BlogPosting on individual post pages — not on list/index pages
if (!isIndex) {
  jsonLdGraph.push({
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "url": canonicalUrl,
    ...(datePublished ? { "datePublished": datePublished, "dateModified": resolvedDateModified } : {}),
    "author": {
      "@type": "Person",
      "@id": "https://raywinkelman.com/#person",
      "name": "Ray Winkelman",
      "url": "https://raywinkelman.com"
    },
    "publisher": {
      "@type": "Organization",
      "@id": "https://raywinkelman.com/#organization",
      "name": "Shadow Software LLC",
      "url": "https://shadowsoftware.com"
    },
    "image": blogPostingImage,
    "mainEntityOfPage": canonicalUrl
  });
}

if (faqItems && faqItems.length > 0) {
  jsonLdGraph.push({
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": jsonLdGraph };
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <script is:inline>
    document.documentElement.classList.add('js');
  </script>
  <ClientRouter />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Ray Winkelman">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="color-scheme" content="dark">
  <meta name="theme-color" content="#060606">

  <meta property="og:type" content={isIndex ? 'website' : 'article'}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content={ogImageWidth}>
  <meta property="og:image:height" content={ogImageHeight}>
  <meta property="og:site_name" content="Ray Winkelman">

  <meta name="twitter:card" content={featuredImage ? 'summary_large_image' : 'summary'}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  <meta name="twitter:image:alt" content={featuredImage ? platformName : 'Big Shadow — avatar of Ray Winkelman, founder of Shadow Software LLC'}>

  <link rel="alternate" hreflang="en" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>

  <!-- Preload LCP asset (AVIF) — featured image takes priority -->
  <link rel="preload" as="image" href={lcpPreload} type={lcpPreloadType} fetchpriority="high">

  <!-- Non-blocking font loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href={fontUrl}>
  <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href={fontUrl}></noscript>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <div id="nav-progress" aria-hidden="true"></div>
  <TopNav currentPath={path} />

  {featuredImageAvif && featuredImageWebp && featuredImage && (
    <figure class="wp-hero reveal">
      <picture>
        <source srcset={featuredImageAvif} type="image/avif">
        <source srcset={featuredImageWebp} type="image/webp">
        <img
          src={featuredImage}
          alt={platformName}
          width="1200"
          height="630"
          fetchpriority="high"
          loading="eager"
          decoding="async"
          onerror="this.closest('.wp-hero').hidden=true"
        >
      </picture>
    </figure>
  )}

  <header class="wp-header reveal">
    <div class="wp-brand">
      <picture>
        <source srcset={logoAvif} type="image/avif">
        <source srcset={logoWebp} type="image/webp">
        <img src={logo} alt={`${platformName} logo`} class="wp-logo" width="48" height="48" fetchpriority={featuredImage ? 'low' : 'high'}>
      </picture>
      <div>
        <h1 class="wp-title">{platformName}</h1>
        <p class="wp-tagline">{tagline}</p>
      </div>
    </div>
    {showVisitLink && <a href={platformUrl} class="wp-visit" rel="noopener noreferrer" target="_blank">Visit site</a>}
  </header>

  <main class="wp-body">
    <slot />
    {faqItems && faqItems.length > 0 && (
      <section class="wp-faq">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="wp-faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </section>
    )}
  </main>

  <ShadowSoftwarePromo variant={promoVariant} />

  <footer class="site-footer reveal">
    <span>&copy; {year} Ray Winkelman &middot; Shadow Software LLC</span>
    <a href="/">Back to profile</a>
  </footer>

  <script>
    import '../scripts/page-init';
  </script>

</body>
</html>
