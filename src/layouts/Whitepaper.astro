---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/whitepaper.css';
import '../styles/ss-promo.css';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  lang?: string;
  logo: string;
  platformName: string;
  platformUrl: string;
  tagline: string;
  path: string;
  datePublished?: string;
  dateModified?: string;
  showVisitLink?: boolean;
  faqItems?: FaqItem[];
  featuredImage?: string;
}

const { title, description, lang = 'en', logo, platformName, platformUrl, tagline, path, datePublished, dateModified, showVisitLink = true, faqItems, featuredImage } = Astro.props;
const year = new Date().getFullYear();
const canonicalUrl = `https://raywinkelman.com${path}`;
const fontUrl = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap';

// Always derive AVIF and WebP paths — all assets have been converted
const logoAvif = logo.replace(/\.[^.]+$/, '.avif');
const logoWebp = logo.replace(/\.[^.]+$/, '.webp');

// Featured image paths (AVIF primary, WebP fallback)
const featuredImageAvif = featuredImage ? featuredImage.replace(/\.[^.]+$/, '.avif') : null;
const featuredImageWebp = featuredImage ? featuredImage.replace(/\.[^.]+$/, '.webp') : null;

// LCP asset to preload — featured image takes priority over logo
const lcpPreload = featuredImageAvif ?? logoAvif;
const lcpPreloadType = 'image/avif';

// OG/Twitter image — featured image (1200×630) or logo fallback
const ogImage = featuredImage ? `https://raywinkelman.com${featuredImageAvif}` : `https://raywinkelman.com${logo}`;
const ogImageWidth = featuredImage ? '1200' : '64';
const ogImageHeight = featuredImage ? '630' : '64';

const resolvedDateModified = dateModified ?? datePublished;

const blogPostingImage = featuredImage
  ? {
      "@type": "ImageObject",
      "url": `https://raywinkelman.com${featuredImageAvif}`,
      "width": 1200,
      "height": 630
    }
  : `https://raywinkelman.com${logo}`;

const jsonLdGraph: object[] = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ray Winkelman", "item": "https://raywinkelman.com/" },
      { "@type": "ListItem", "position": 2, "name": platformName, "item": canonicalUrl }
    ]
  },
  {
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "url": canonicalUrl,
    ...(datePublished ? { "datePublished": datePublished, "dateModified": resolvedDateModified } : {}),
    "author": {
      "@type": "Person",
      "@id": "https://raywinkelman.com/#person",
      "name": "Ray Winkelman",
      "url": "https://raywinkelman.com"
    },
    "publisher": {
      "@type": "Organization",
      "@id": "https://raywinkelman.com/#organization",
      "name": "Shadow Software LLC",
      "url": "https://raywinkelman.com"
    },
    "image": blogPostingImage,
    "mainEntityOfPage": canonicalUrl
  }
];

if (faqItems && faqItems.length > 0) {
  jsonLdGraph.push({
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": jsonLdGraph };
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <script is:inline>
    document.documentElement.classList.add('js');
    (function(){const t=localStorage.getItem('theme');if(t==='dark'||t==='light')document.documentElement.setAttribute('data-theme',t);})();
  </script>
  <ClientRouter />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Ray Winkelman">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="theme-color" content="#f5f4f0" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)">

  <meta property="og:type" content="article">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content={ogImageWidth}>
  <meta property="og:image:height" content={ogImageHeight}>
  <meta property="og:site_name" content="Ray Winkelman">

  <meta name="twitter:card" content={featuredImage ? 'summary_large_image' : 'summary'}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="alternate" hreflang="en" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>

  <!-- Preload LCP asset (AVIF) — featured image takes priority -->
  <link rel="preload" as="image" href={lcpPreload} type={lcpPreloadType} fetchpriority="high">

  <!-- Non-blocking font loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href={fontUrl}>
  <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href={fontUrl}></noscript>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <nav class="top-nav" aria-label="Site navigation">
    <a href="/">Resume</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/americanguntrader/" aria-current={path === '/americanguntrader/' ? 'page' : undefined}>AGT</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/dabdash/" aria-current={path === '/dabdash/' ? 'page' : undefined}>DabDash</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <a href="/blog/" aria-current={path.startsWith('/blog') ? 'page' : undefined}>Blog</a>
    <span class="nav-sep" aria-hidden="true">/</span>
    <button class="theme-toggle" type="button" aria-label="Toggle theme">
      <svg class="icon-sun" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="6.5" cy="6.5" r="2.25"/>
        <line x1="6.5" y1="0.5" x2="6.5" y2="1.75"/>
        <line x1="6.5" y1="11.25" x2="6.5" y2="12.5"/>
        <line x1="0.5" y1="6.5" x2="1.75" y2="6.5"/>
        <line x1="11.25" y1="6.5" x2="12.5" y2="6.5"/>
        <line x1="2.4" y1="2.4" x2="3.3" y2="3.3"/>
        <line x1="9.7" y1="9.7" x2="10.6" y2="10.6"/>
        <line x1="10.6" y1="2.4" x2="9.7" y2="3.3"/>
        <line x1="3.3" y1="9.7" x2="2.4" y2="10.6"/>
      </svg>
      <svg class="icon-moon" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.5 8A5 5 0 0 1 5 2.5a5 5 0 1 0 5.5 5.5z"/>
      </svg>
    </button>
  </nav>

  {featuredImageAvif && featuredImageWebp && featuredImage && (
    <figure class="wp-hero reveal">
      <picture>
        <source srcset={featuredImageAvif} type="image/avif">
        <source srcset={featuredImageWebp} type="image/webp">
        <img
          src={featuredImage}
          alt={platformName}
          width="1200"
          height="630"
          fetchpriority="high"
          loading="eager"
          decoding="async"
          onerror="this.closest('.wp-hero').hidden=true"
        >
      </picture>
    </figure>
  )}

  <header class="wp-header reveal">
    <div class="wp-brand">
      <picture>
        <source srcset={logoAvif} type="image/avif">
        <source srcset={logoWebp} type="image/webp">
        <img src={logo} alt={`${platformName} logo`} class="wp-logo" width="48" height="48" fetchpriority={featuredImage ? 'low' : 'high'}>
      </picture>
      <div>
        <h1 class="wp-title">{platformName}</h1>
        <p class="wp-tagline">{tagline}</p>
      </div>
    </div>
    {showVisitLink && <a href={platformUrl} class="wp-visit" rel="noopener noreferrer" target="_blank">Visit site</a>}
  </header>

  <main class="wp-body">
    <slot />
    {faqItems && faqItems.length > 0 && (
      <section class="wp-faq">
        <h2>Frequently Asked Questions</h2>
        {faqItems.map((item) => (
          <div class="wp-faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </section>
    )}
  </main>

  <aside class="ss-promo reveal" aria-label="Sponsored — Shadow Software LLC">
    <div class="ss-promo-inner">
      <div class="ss-promo-brand">
        <img src="/logos/shadow-software.webp" alt="Shadow Software LLC" class="ss-promo-logo" width="32" height="32">
        <span class="ss-promo-sponsor">Shadow Software LLC</span>
      </div>
      <p class="ss-promo-eyebrow">You found this article through search — that's not an accident.</p>
      <h2 class="ss-promo-heading">We build <em>search visibility</em> for serious brands.</h2>
      <p class="ss-promo-body">SEO &amp; AEO services that get your business in front of people the moment they're asking the right questions — in Google, and in AI.</p>
      <div class="ss-promo-pills">
        <span class="ss-promo-pill">Technical SEO</span>
        <span class="ss-promo-pill">Answer Engine Optimization</span>
        <span class="ss-promo-pill">Content Strategy</span>
        <span class="ss-promo-pill">AI Search Visibility</span>
      </div>
      <a href="https://shadowsoftware.com/services/seo" class="ss-promo-cta" target="_blank" rel="noopener noreferrer sponsored">
        Get found like this
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="2" y1="7" x2="12" y2="7"/>
          <polyline points="8 3 12 7 8 11"/>
        </svg>
      </a>
    </div>
  </aside>

  <footer class="site-footer reveal">
    <span>&copy; {year} Ray Winkelman &middot; Shadow Software LLC</span>
    <a href="/">Back to resume</a>
  </footer>

  <script>
    import '../scripts/page-init';
  </script>

</body>
</html>
